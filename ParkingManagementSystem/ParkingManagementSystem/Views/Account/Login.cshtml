@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng nhập - Parking Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: #f4f7f6;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            width: 400px;
        }

        .btn-primary {
            background: #0d6efd;
            border: none;
            padding: 12px;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="card login-card">
        <div class="card-header bg-primary text-white text-center py-4" style="border-radius: 15px 15px 0 0;">
            <h4 class="mb-0"><i class="fa fa-parking me-2"></i>HỆ THỐNG GỬI XE</h4>
        </div>
        <div class="card-body p-4">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 small">@ViewBag.Error</div>
            }

            <form asp-action="Login" method="post">
                <label class="form-label small fw-bold text-muted">BẠN ĐĂNG NHẬP VỚI TƯ CÁCH:</label>
                <div class="btn-group w-100 mb-4" role="group">
                    <input type="radio" class="btn-check" name="selectedRole" id="roleStaff" value="Staff" checked>
                    <label class="btn btn-outline-primary" for="roleStaff"><i class="fa fa-user me-1"></i> Nhân viên</label>

                    <input type="radio" class="btn-check" name="selectedRole" id="roleAdmin" value="Admin">
                    <label class="btn btn-outline-primary" for="roleAdmin"><i class="fa fa-user-shield me-1"></i> Admin</label>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-bold">Tên đăng nhập</label>
                    <input name="username" class="form-control" required />
                </div>
                <div class="mb-4">
                    <label class="form-label small fw-bold">Mật khẩu</label>
                    <input name="password" type="password" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary w-100 shadow-sm">ĐĂNG NHẬP NGAY</button>
            </form>
        </div>
    </div>
</body>
</html>