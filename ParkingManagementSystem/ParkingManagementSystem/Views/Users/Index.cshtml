@model IEnumerable<ParkingManagementSystem.Models.User>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold"><i class="fa fa-users-cog me-2"></i> QUẢN LÝ NHÂN VIÊN</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="fa fa-plus me-1"></i> Thêm Nhân Viên</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Họ Tên</th>
                    <th>Tên Đăng Nhập</th>
                    <th>Quyền</th>
                    <th>Số Điện Thoại</th>
                    <th>Trạng Thái</th>
                    <th class="text-end pe-4">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@item.FullName</td>
                        <td><code class="text-primary">@item.UserName</code></td>
                        <td>
                            <span class="badge @(item.Role == "Admin" ? "bg-danger" : "bg-info")">
                                @item.Role
                            </span>
                        </td>
                        <td>@item.PhoneNumber</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="text-success"><i class="fa fa-check-circle me-1"></i> Đang hoạt động</span>
                            }
                            else
                            {
                                <span class="text-muted"><i class="fa fa-times-circle me-1"></i> Khóa</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <a asp-action="Edit" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-warning"><i class="fa fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-danger" onclick="return confirm('Xác nhận xóa nhân viên này?')"><i class="fa fa-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>