@model ParkingManagementSystem.Models.User
@{
    ViewData["Title"] = "Thêm nhân viên";
}

<div class="container mt-4">
    <div class="card border-0 shadow-sm mx-auto" style="max-width: 600px;">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="fa fa-user-plus me-2"></i> THÊM NHÂN VIÊN MỚI</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-bold small text-muted text-uppercase">Họ và Tên</label>
                    <input asp-for="FullName" class="form-control form-control-lg border-0 bg-light" placeholder="Nguyễn Văn A" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="UserName" class="form-label fw-bold small text-muted text-uppercase">Tên đăng nhập</label>
                        <input asp-for="UserName" class="form-control border-0 bg-light" placeholder="user01" />
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Password" class="form-label fw-bold small text-muted text-uppercase">Mật khẩu (Ít nhất 6 ký tự)</label>
                        <input asp-for="Password" type="password" class="form-control border-0 bg-light" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Role" class="form-label fw-bold small text-muted text-uppercase">Quyền hạn</label>
                        <select asp-for="Role" class="form-select border-0 bg-light">
                            <option value="Staff">Nhân viên (Staff)</option>
                            <option value="Admin">Quản trị viên (Admin)</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="PhoneNumber" class="form-label fw-bold small text-muted text-uppercase">Số điện thoại (10 số)</label>
                        <input asp-for="PhoneNumber" class="form-control border-0 bg-light" placeholder="0901234567" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>
                </div>

                <hr class="my-4">
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-lg flex-grow-1 fw-bold">LƯU THÔNG TIN</button>
                    <a asp-action="Index" class="btn btn-light btn-lg fw-bold px-4">HỦY</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}